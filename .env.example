# Application
APP_NAME=SmartATS
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# PostgreSQL / pgvector
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smartats
POSTGRES_USER=smartats
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://smartats:change_me@localhost:5432/smartats

# Redis / background coordination
REDIS_URL=redis://localhost:6379/0

# LLM providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# MCP host
MCP_HOST=localhost
MCP_PORT=8765
MCP_TOOL_REGISTRY_PATH=src/backend/modules/mcp-host/tools

# Resume ingestion
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=25
ALLOWED_RESUME_EXTENSIONS=pdf,docx

# External integrations
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=smartats-events
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_CALENDAR_ID=primary

# Security
JWT_SECRET=change_me_in_local_env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
